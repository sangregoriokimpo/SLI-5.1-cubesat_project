<?xml version="1.0"?>
<robot name="smallsat">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.3"/>
      </geometry>
      <material name="smallsat_silver">
        <color rgba="0.75 0.75 0.80 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <!-- Inertia of solid box: Ixx = (1/12)*m*(y^2+z^2) etc -->
      <!-- m=2kg, x=0.1, y=0.1, z=0.3                         -->
      <!-- Ixx = (1/12)*2*(0.01+0.09) = 0.01667               -->
      <!-- Iyy = (1/12)*2*(0.01+0.09) = 0.01667               -->
      <!-- Izz = (1/12)*2*(0.01+0.01) = 0.00333               -->
      <inertia ixx="0.01667" ixy="0.0" ixz="0.0"
                              iyy="0.01667" iyz="0.0"
                                            izz="0.00333"/>
    </inertial>
  </link>
</robot>