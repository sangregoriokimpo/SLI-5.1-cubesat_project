<?xml version="1.0"?>
<robot name="smallsat">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.3"/>
      </geometry>
      <material name="smallsat_silver">
        <color rgba="0.75 0.75 0.80 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <!-- Inertia of solid box: Ixx = (1/12)*m*(y^2+z^2) etc -->
      <!-- m=2kg, x=0.1, y=0.1, z=0.3                         -->
      <!-- Ixx = (1/12)*2*(0.01+0.09) = 0.01667               -->
      <!-- Iyy = (1/12)*2*(0.01+0.09) = 0.01667               -->
      <!-- Izz = (1/12)*2*(0.01+0.01) = 0.00333               -->
      <inertia ixx="0.01667" ixy="0.0" ixz="0.0"
                              iyy="0.01667" iyz="0.0"
                                            izz="0.00333"/>
    </inertial>
  </link>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.005"/>
      </geometry>
      <material name="lidar_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <link name="ir_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.005 0.015"/>
      </geometry>
      <material name="ir_dark">
        <color rgba="0.2 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Lidar on +Y face, boresight = +Z rotated to +Y -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="-0.02 0.05 0" rpy="-1.5708 0 0"/>
  </joint>

  <!-- IR camera on +Y face, same orientation -->
  <joint name="ir_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="ir_camera_link"/>
    <origin xyz="0.02 0.05 0" rpy="-1.5708 0 0"/>
  </joint>

</robot>